---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalURL?: string;
  slug?: string;
  robots?: string;
}

const {
  title,
  description = 'Блог Дмитрия Иноземцева об искусственном интеллекте, триатлоне и удалённой работе. Честные эксперименты, тренировки, обзоры и практический опыт',
  ogImage,
  ogType = 'website',
  canonicalURL = Astro.url.toString().replace(/\/?$/, '/'),
  slug,
  robots = 'index, follow',
} = Astro.props;

const isNoindex = robots.includes('noindex');

const siteOrigin = Astro.site?.origin ?? 'https://dimino.me';
const relativeOgImage = ogImage ?? (slug ? `/api/og/${slug}.png` : '/api/og/default.png');
const resolvedOgImage = relativeOgImage.startsWith('http')
  ? relativeOgImage
  : `${siteOrigin}${relativeOgImage}`;

const siteTitle = title.includes('Дмитрий Иноземцев') ? title : `${title} — Дмитрий Иноземцев`;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    {isNoindex ? null : <link rel="canonical" href={canonicalURL} />}
    <meta name="robots" content={robots} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    {isNoindex ? null : <meta property="og:url" content={canonicalURL} />}
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={siteTitle} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="Дмитрий Иноземцев" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Yandex Webmaster -->
    <meta name="yandex-verification" content="6af3db3095342d38" />

    <slot name="head-extra" />
  </head>
  <body class="bg-white font-[Inter,sans-serif] min-h-screen text-gray-900 antialiased">
    <slot />

    <slot name="body-extra" />
    <CookieBanner />
  </body>
</html>
