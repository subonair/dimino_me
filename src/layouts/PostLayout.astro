---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  datePublished: string;
  canonicalURL?: string;
  slug?: string;
  image?: string;
}

const {
  title,
  description,
  ogImage,
  datePublished,
  canonicalURL = Astro.url.toString().replace(/\/?$/, '/'),
  slug,
  image,
} = Astro.props;

const siteOrigin = Astro.site?.origin ?? 'https://dimino.me';

// Prefer frontmatter image for OG, then explicit ogImage, then Satori fallback
const _relativeOgImage =
  ogImage ??
  (image ? (image.startsWith('http') ? image : `${siteOrigin}${image}`) : undefined) ??
  (slug ? `/api/og/${slug}.png` : '/api/og/default.png');
const resolvedOgImage = _relativeOgImage.startsWith('http')
  ? _relativeOgImage
  : `${siteOrigin}${_relativeOgImage}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description || undefined,
  datePublished,
  author: {
    '@type': 'Person',
    name: 'Дмитрий Иноземцев',
    url: 'https://dimino.me/about/',
  },
  publisher: {
    '@type': 'Person',
    name: 'Дмитрий Иноземцев',
  },
  image: resolvedOgImage,
  url: canonicalURL,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
};
---

<Base
  title={title}
  description={description}
  ogImage={resolvedOgImage}
  ogType="article"
  canonicalURL={canonicalURL}
  slug={slug}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <Header />
  <main class="max-w-3xl mx-auto px-4 py-10">
    <slot />
  </main>
  <Footer />
</Base>
