---
interface Props {
  title: string;
  slug: string;
  date: Date;
  city: string;
  sportType: 'triathlon' | 'swimrun' | 'aquathlon' | 'swim' | 'run';
  status: 'open' | 'low' | 'sold_out' | 'waitlist';
  distances: {
    swim?: number;
    bike?: number;
    run?: number;
  };
}

const { title, slug, date, city, sportType, status, distances } = Astro.props;

const formattedDate = date.toLocaleDateString('ru-RU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const sportLabels: Record<string, string> = {
  triathlon: '🏊‍♂️🚴‍♂️🏃 Триатлон',
  swimrun: '🏊‍♂️🏃 Свимран',
  aquathlon: '🏊‍♂️🏃 Акватлон',
  swim: '🏊‍♂️ Плавание',
  run: '🏃 Бег',
};

const statusLabels: Record<string, { label: string; color: string }> = {
  open: { label: 'Открыта', color: 'bg-green-100 text-green-700' },
  low: { label: 'Мало слотов', color: 'bg-yellow-100 text-yellow-700' },
  sold_out: { label: 'Продано', color: 'bg-red-100 text-red-700' },
  waitlist: { label: 'Лист ожидания', color: 'bg-gray-100 text-gray-600' },
};
---

<article>
  <a
    href={`/triatlon/events/${slug}/`}
    class="group block bg-white border border-gray-100 rounded-xl p-5 hover:border-gray-200 hover:shadow-sm transition-all"
  >
    <div class="flex items-start justify-between gap-2">
      <h2 class="text-base font-semibold text-gray-900 group-hover:text-gray-600 transition-colors">
        {title}
      </h2>
      <span
        class={`shrink-0 px-2 py-0.5 rounded-full text-xs font-medium ${statusLabels[status]?.color || 'bg-gray-100 text-gray-600'}`}
      >
        {statusLabels[status]?.label || status}
      </span>
    </div>

    <div class="mt-2 flex items-center gap-2 text-sm text-gray-500">
      <time datetime={date.toISOString().split('T')[0]}>{formattedDate}</time>
      <span aria-hidden="true">·</span>
      <span>{city}</span>
    </div>

    <div class="mt-1.5 text-xs text-gray-400">
      {sportLabels[sportType] || sportType}
    </div>

    {
      distances && (
        <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500">
          {distances.swim != null && <span>🏊 {distances.swim} км</span>}
          {distances.bike != null && <span>🚴 {distances.bike} км</span>}
          {distances.run != null && <span>🏃 {distances.run} км</span>}
        </div>
      )
    }
  </a>
</article>
