---
interface PriceLevel {
  level: number;
  price: number;
}

interface PriceCategory {
  category: string;
  levels: PriceLevel[];
}

interface Props {
  title: string;
  date: Date;
  city: string;
  sportType: 'triathlon' | 'swimrun' | 'aquathlon' | 'swim' | 'run' | 'bike' | 'duathlon';
  status: 'open' | 'low' | 'sold_out' | 'waitlist';
  distances: {
    swim?: number;
    bike?: number;
    run?: number;
  };
  sourceUrl?: string;
  prices?: PriceCategory[];
}

const {
  title,
  date,
  city,
  sportType,
  status,
  distances,
  sourceUrl,
  prices,
} = Astro.props;

const sportTypeConfig: Record<string, { icon: string; label: string }> = {
  triathlon: { icon: '🏊🚴🏃', label: 'Триатлон' },
  swimrun: { icon: '🏊🏃', label: 'Swimrun' },
  aquathlon: { icon: '🏊🏃', label: 'Акватлон' },
  swim: { icon: '🏊', label: 'Плавание' },
  run: { icon: '🏃', label: 'Бег' },
  bike: { icon: '🚴', label: 'Велосипед' },
  duathlon: { icon: '🚴🏃', label: 'Дуатлон' },
};

const formattedDate = date.toLocaleDateString('ru-RU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const statusConfig: Record<string, { label: string; color: string }> = {
  open: { label: 'Открыта', color: 'bg-green-100 text-green-700' },
  low: { label: 'Мало слотов', color: 'bg-yellow-100 text-yellow-700' },
  sold_out: { label: 'Продано', color: 'bg-red-100 text-red-700' },
  waitlist: { label: 'Лист ожидания', color: 'bg-gray-100 text-gray-600' },
};

// Format distance labels
const distanceParts: string[] = [];
if (distances.swim != null) distanceParts.push(`🏊 ${distances.swim} км`);
if (distances.bike != null) distanceParts.push(`🚴 ${distances.bike} км`);
if (distances.run != null) distanceParts.push(`🏃 ${distances.run} км`);

const externalUrl = sourceUrl || 'https://iron-star.com/event/';
---

<article
  class="group relative bg-white border border-gray-100 rounded-xl p-5 hover:border-gray-200 hover:shadow-sm transition-all"
>
  <!-- Status badge — top right -->
  <span
    class={`absolute top-3 right-3 shrink-0 px-2 py-0.5 rounded-full text-xs font-medium ${statusConfig[status]?.color || 'bg-gray-100 text-gray-600'}`}
  >
    {statusConfig[status]?.label || status}
  </span>

  <!-- Title -->
  <h2
    class="text-base font-semibold text-gray-900 group-hover:text-gray-600 transition-colors pr-20"
  >
    {title}
  </h2>

  <!-- Date + City -->
  <div class="mt-1 flex items-center gap-2 text-sm text-gray-500">
    <time datetime={date.toISOString().split('T')[0]}>{formattedDate}</time>
    <span aria-hidden="true">·</span>
    <span>{city}</span>
  </div>

  <!-- Sport type -->
  <div class="mt-0.5 text-xs text-gray-400 flex items-center gap-1">
    <span>{sportTypeConfig[sportType]?.icon}</span>
    <span>{sportTypeConfig[sportType]?.label || sportType}</span>
  </div>

  <!-- Distances -->
  {
    distanceParts.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-xs text-gray-500">
        {distanceParts.map((part) => (
          <span>{part}</span>
        ))}
      </div>
    )
  }

  <!-- Prices -->
  {
    prices && prices.length > 0 && (
      <div class="mt-2 text-xs text-gray-500">
        {prices.map((cat) => (
          <div class="flex flex-wrap gap-x-3 gap-y-0.5">
            <span class="font-medium text-gray-600">{cat.category}:</span>
            {cat.levels.map((l) => (
              <span>
                {l.level} ур. — {l.price.toLocaleString('ru-RU')} ₽
              </span>
            ))}
          </div>
        ))}
      </div>
    )
  }

  <!-- CTA button -->
  <div class="mt-3">
    <a
      href={externalUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors"
    >
      На сайт IronStar
      <span class="text-xs" aria-hidden="true">→</span>
    </a>
  </div>
</article>
