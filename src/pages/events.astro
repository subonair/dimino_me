---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import EventCard from '../components/EventCard.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const events = (await getCollection('events')).sort(
  (a, b) => a.data.date.valueOf() - b.data.date.valueOf(),
);

const now = new Date();
const upcoming = events.filter((e) => e.data.date >= now);
const past = events.filter((e) => e.data.date < now);

// Gather all unique filter values
const allTypes = [...new Set(events.map((e) => e.data.sportType))].sort();
const allAudiences = [...new Set(events.map((e) => e.data.audience))].sort();

// Distance labels: 7 named chips + dropdown for "другая"
const namedLabels: { value: string; icon: string; label: string }[] = [
  { value: 'суперпринт', icon: '⚡', label: 'Суперпринт' },
  { value: 'спринт', icon: '💨', label: 'Спринт' },
  { value: 'олимпийская', icon: '🏅', label: 'Олимпийская' },
  { value: 'полужелезная', icon: '🔥', label: 'Полужелезная' },
  { value: 'железная', icon: '🦾', label: 'Железная' },
  { value: 'полумарафон', icon: '🏃', label: 'Полумарафон' },
  { value: 'марафон', icon: '🏟️', label: 'Марафон' },
];
// Collect "другая" titles for the dropdown
const otherTitles = [
  ...new Set(events.filter((e) => e.data.distanceLabel === 'другая').map((e) => e.data.title)),
].sort();

// Audience display config
const audienceConfig: Record<string, { icon: string; label: string }> = {
  all: { icon: '🌐', label: 'Все' },
  men: { icon: '🏃‍♂️', label: 'Мужчины' },
  women: { icon: '🏃‍♀️', label: 'Женщины' },
  children: { icon: '🧒', label: 'Дети' },
};

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Календарь стартов',
  description:
    'Календарь стартов по триатлону, бегу, плаванию и другим видам спорта. Ближайшие и прошедшие события от IronStar и RussiaRunning.',
  url: 'https://dimino.me/events/',
  isPartOf: {
    '@type': 'WebSite',
    name: 'Дмитрий Иноземцев',
    url: 'https://dimino.me',
  },
};
---

<Base
  title="Календарь стартов"
  description="Календарь стартов по триатлону, бегу, плаванию и другим видам спорта. Ближайшие и прошедшие события от IronStar и RussiaRunning."
>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  <Header />
  <Breadcrumbs items={[{ label: 'Главная', href: '/' }, { label: 'Календарь стартов' }]} />

  <main class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900">Календарь стартов</h1>
    <p class="mt-3 text-gray-500">
      События по триатлону, бегу и плаванию в России и за её пределами.
    </p>

    <div class="mt-6 bg-blue-50 border border-blue-100 rounded-2xl p-5 text-sm text-gray-700">
      <p>
        В поиске стартов я столкнулся с проблемой - сложно в одном месте найти всю информацию по
        всем стартам. Для моего удобства, с помощью ИИ-агентов, я собрал информацию из открытых
        источников. Сейчас в базе 3 источника и она постоянно пополняется.
      </p>
      <p class="mt-2">
        Не нашли свой старт?
        <a
          href="https://t.me/subonair"
          class="font-medium text-blue-600 hover:underline"
          target="_blank">Напишите мне в Telegram</a
        > — я добавлю его в Календарь стартов.
      </p>
    </div>

    <!-- Filter: Sport type (multiselect chips) -->
    <div class="mt-8" id="filter-sport">
      <label class="block text-xs font-medium text-gray-400 uppercase tracking-wide mb-2"
        >Тип занятия</label
      >
      <div class="flex flex-wrap gap-2" id="sport-chips">
        {
          allTypes.map((type) => (
            <button
              class="filter-chip px-3 py-1.5 rounded-full text-sm font-medium border transition-colors cursor-pointer bg-white border-gray-200 text-gray-500"
              data-filter="type"
              data-value={type}
            >
              {type === 'triathlon' && '🏊🚴🏃 Триатлон'}
              {type === 'swim' && '🏊 Плавание'}
              {type === 'run' && '🏃 Бег'}
              {type === 'bike' && '🚴 Вело'}
              {type === 'aquathlon' && '🏊🏃 Акватлон'}
              {type === 'swimrun' && '🏊🏃 Swimrun'}
              {type === 'duathlon' && '🚴🏃 Дуатлон'}
              {type === 'nordic_walking' && '🥾 Скандинавская ходьба'}
            </button>
          ))
        }
      </div>
    </div>

    <!-- Filter: Distance label (7 chips + dropdown) -->
    <div class="mt-4" id="filter-distance">
      <label class="block text-xs font-medium text-gray-400 uppercase tracking-wide mb-2"
        >Дистанция</label
      >
      <div class="flex flex-wrap gap-2 items-center">
        {
          namedLabels.map((dl) => (
            <button
              class="filter-chip px-3 py-1.5 rounded-full text-sm font-medium border transition-colors cursor-pointer bg-white border-gray-200 text-gray-500"
              data-filter="label"
              data-value={dl.value}
            >
              {dl.icon} {dl.label}
            </button>
          ))
        }
        <!-- Dropdown for "другая" distances -->
        {
          otherTitles.length > 0 && (
            <div class="relative inline-block">
              <select
                id="other-distance-select"
                class="appearance-none pl-3 pr-8 py-1.5 rounded-full text-sm font-medium border transition-colors cursor-pointer bg-white border-gray-200 text-gray-500 hover:border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-200 focus:border-blue-300"
                data-filter="title"
              >
                <option value="">Другие ↓</option>
                {otherTitles.map((t) => (
                  <option value={t}>{t}</option>
                ))}
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2">
                <svg
                  class="h-4 w-4 text-gray-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </div>
            </div>
          )
        }
      </div>
    </div>

    <!-- Filter: Audience (multiselect chips) -->
    <div class="mt-4" id="filter-audience">
      <label class="block text-xs font-medium text-gray-400 uppercase tracking-wide mb-2"
        >Участники</label
      >
      <div class="flex flex-wrap gap-2" id="audience-chips">
        {
          allAudiences
            .filter((a) => a !== 'all')
            .map((aud) => (
              <button
                class="filter-chip px-3 py-1.5 rounded-full text-sm font-medium border transition-colors cursor-pointer bg-white border-gray-200 text-gray-500"
                data-filter="audience"
                data-value={aud}
              >
                {audienceConfig[aud]?.icon} {audienceConfig[aud]?.label}
              </button>
            ))
        }
      </div>
    </div>

    <!-- Upcoming events -->
    {
      upcoming.length > 0 && (
        <section class="mt-10" id="upcoming-section">
          <h2 class="text-xl font-semibold text-gray-800">
            Ближайшие старты (<span id="upcoming-count">{upcoming.length}</span>)
          </h2>

          <div class="mt-4 space-y-2" id="upcoming-list">
            {upcoming.map((event) => (
              <div
                class="event-item"
                data-type={event.data.sportType}
                data-label={event.data.distanceLabel}
                data-title={event.data.title}
                data-audience={event.data.audience}
              >
                <EventCard
                  title={event.data.title}
                  date={event.data.date}
                  city={event.data.city}
                  sportType={event.data.sportType}
                  status={event.data.status}
                  audience={event.data.audience}
                  distances={event.data.distances}
                  distanceLabel={event.data.distanceLabel}
                  sourceUrl={event.data.sourceUrl}
                  prices={event.data.prices}
                />
              </div>
            ))}
          </div>
        </section>
      )
    }

    <!-- Past events (collapsed) -->
    {
      past.length > 0 && (
        <section class="mt-10" id="past-section">
          <details id="past-details">
            <summary class="text-xl font-semibold text-gray-800 cursor-pointer">
              Прошедшие старты (<span id="past-count">{past.length}</span>)
            </summary>

            <div class="mt-4 space-y-2" id="past-list">
              {past.map((event) => (
                <div
                  class="event-item"
                  data-type={event.data.sportType}
                  data-label={event.data.distanceLabel}
                  data-title={event.data.title}
                  data-audience={event.data.audience}
                >
                  <EventCard
                    title={event.data.title}
                    date={event.data.date}
                    city={event.data.city}
                    sportType={event.data.sportType}
                    status={event.data.status}
                    audience={event.data.audience}
                    distances={event.data.distances}
                    distanceLabel={event.data.distanceLabel}
                    sourceUrl={event.data.sourceUrl}
                    prices={event.data.prices}
                  />
                </div>
              ))}
            </div>
          </details>
        </section>
      )
    }

    <div class="mt-8">
      <a href="/triatlon/" class="text-sm text-blue-600 hover:text-blue-800 transition-colors">
        ← К триатлону
      </a>
    </div>
  </main>

  <Footer />
</Base>

<script>
  const chips = document.querySelectorAll('.filter-chip');
  const otherSelect = document.getElementById('other-distance-select') as HTMLSelectElement | null;
  const eventItems = document.querySelectorAll('.event-item');

  const activeStyles = ['bg-blue-50', 'border-blue-200', 'text-blue-700'];
  const inactiveStyles = ['bg-white', 'border-gray-200', 'text-gray-500'];

  // Parse URL params on load
  function getParams(): Record<string, Set<string>> {
    const params: Record<string, Set<string>> = {};
    const search = new URLSearchParams(window.location.search);
    for (const [key, value] of search.entries()) {
      if (!params[key]) params[key] = new Set();
      params[key].add(value);
    }
    // Also check path: /events/run → type=run
    const pathMatch = window.location.pathname.match(/^\/events\/([a-z_]+)\/?$/);
    if (pathMatch) {
      const sport = pathMatch[1];
      if (!params['type']) params['type'] = new Set();
      params['type'].add(sport);
    }
    return params;
  }

  function setParams(params: Record<string, Set<string>>) {
    const hasTypeOnly =
      params.type?.size === 1 && !params.label && !params.title && !params.audience;
    if (hasTypeOnly) {
      // Clean URL: /events/run/
      const type = [...params.type!][0];
      window.history.replaceState(null, '', `/events/${type}/`);
    } else {
      // Query params: /events/?type=run&label=olympic
      const search = new URLSearchParams();
      for (const [key, values] of Object.entries(params)) {
        for (const v of values) {
          search.append(key, v);
        }
      }
      const qs = search.toString();
      const url = `/events/${qs ? '?' + qs : ''}`;
      window.history.replaceState(null, '', url);
    }
  }

  // Initialize chips from URL params
  function initFromUrl() {
    const params = getParams();
    chips.forEach((chip) => {
      const filterType = (chip as HTMLElement).dataset.filter!;
      const value = (chip as HTMLElement).dataset.value!;
      if (params[filterType]?.has(value)) {
        activateChip(chip);
      }
    });
    // Initialize dropdown from URL params
    if (otherSelect && params['title']?.size) {
      const title = [...params['title']][0];
      otherSelect.value = title;
      if (!otherSelect.value) {
        // Value not in options, reset
        otherSelect.value = '';
      }
    }
    updateFilters();
  }

  function activateChip(chip: Element) {
    chip.classList.remove(...inactiveStyles);
    chip.classList.add(...activeStyles);
  }

  function deactivateChip(chip: Element) {
    chip.classList.remove(...activeStyles);
    chip.classList.add(...inactiveStyles);
  }

  function isActiveChip(chip: Element): boolean {
    return chip.classList.contains('bg-blue-50');
  }

  function getActiveFilters(): Record<string, Set<string>> {
    const filters: Record<string, Set<string>> = {};
    chips.forEach((chip) => {
      if (isActiveChip(chip)) {
        const filterType = (chip as HTMLElement).dataset.filter!;
        const value = (chip as HTMLElement).dataset.value!;
        if (!filters[filterType]) filters[filterType] = new Set();
        filters[filterType].add(value);
      }
    });
    // Add dropdown selection
    if (otherSelect && otherSelect.value) {
      if (!filters['title']) filters['title'] = new Set();
      filters['title'].add(otherSelect.value);
    }
    return filters;
  }

  function updateFilters() {
    const active = getActiveFilters();
    const hasType = active.type?.size > 0;
    const hasLabel = active.label?.size > 0;
    const hasTitle = active.title?.size > 0;
    const hasAudience = active.audience?.size > 0;
    const hasAnyFilter = hasType || hasLabel || hasTitle || hasAudience;

    let upcomingVisible = 0;
    let pastVisible = 0;

    eventItems.forEach((el) => {
      const type = (el as HTMLElement).dataset.type!;
      const label = (el as HTMLElement).dataset.label!;
      const title = (el as HTMLElement).dataset.title!;
      const audience = (el as HTMLElement).dataset.audience!;

      // Show if ALL active filters match (AND between groups, OR within group)
      const typeMatch = !hasType || active.type!.has(type);
      // Label match: chip label OR if label is "другая" and a title filter is active, check title match
      const labelMatch = !hasLabel || active.label!.has(label) || (label === 'другая' && hasTitle);
      const titleMatch = !hasTitle || (label === 'другая' && active.title!.has(title));
      // Audience: "all" events should show for any audience filter
      const audienceMatch = !hasAudience || active.audience!.has(audience) || audience === 'all';

      if (
        (hasAnyFilter && typeMatch && labelMatch && titleMatch && audienceMatch) ||
        !hasAnyFilter
      ) {
        (el as HTMLElement).style.display = '';
        const section = el.closest('#upcoming-list, #past-list');
        if (section?.id === 'upcoming-list') upcomingVisible++;
        else pastVisible++;
      } else {
        (el as HTMLElement).style.display = 'none';
      }
    });

    // Update counts
    const uc = document.getElementById('upcoming-count');
    const pc = document.getElementById('past-count');
    if (uc) uc.textContent = String(upcomingVisible);
    if (pc) pc.textContent = String(pastVisible);

    // Hide sections if empty
    const upcomingSection = document.getElementById('upcoming-section');
    const pastSection = document.getElementById('past-section');
    if (upcomingSection) upcomingSection.style.display = upcomingVisible > 0 ? '' : 'none';
    if (pastSection) pastSection.style.display = pastVisible > 0 ? '' : 'none';

    // Update URL
    setParams(active);
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      if (isActiveChip(chip)) {
        deactivateChip(chip);
      } else {
        activateChip(chip);
      }
      updateFilters();
    });
  });

  // Dropdown change
  otherSelect?.addEventListener('change', () => {
    updateFilters();
  });

  // Initialize from URL on page load
  initFromUrl();
</script>
