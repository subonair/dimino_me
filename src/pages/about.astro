---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TelegramCTA from '../components/TelegramCTA.astro';

const person = {
  name: 'itrokit',
  jobTitle: 'Продуктовый менеджер, энтузиаст ИИ и триатлет',
  url: 'https://dimino.me',
  sameAs: ['https://t.me/itrokit'],
  description:
    'Работаю в продукте, слежу за ИИ и финишировал несколько триатлонов. Пишу о том, что сам проверяю.',
};
---

<Base title="Обо мне" description={person.description}>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: person.name,
      jobTitle: person.jobTitle,
      url: person.url,
      sameAs: person.sameAs,
      description: person.description,
    })}
  />

  <Header />

  <main class="max-w-3xl mx-auto px-4 py-10">
    <div class="flex flex-col sm:flex-row gap-8 items-start">
      <!-- Avatar placeholder -->
      <div
        class="shrink-0 w-24 h-24 sm:w-32 sm:h-32 rounded-2xl bg-gray-100 flex items-center justify-center text-4xl select-none"
        aria-hidden="true"
      >
        🧑‍💻
      </div>

      <div class="flex-1">
        <h1 class="text-3xl font-bold text-gray-900">{person.name}</h1>
        <p class="mt-1 text-gray-500 text-sm">{person.jobTitle}</p>

        <p class="mt-5 text-gray-700 leading-relaxed">
          {person.description}
        </p>

        <p class="mt-4 text-gray-700 leading-relaxed">
          Интересуюсь практическим применением ИИ в работе и жизни. Тренируюсь на длинные дистанции
          — плавание, велосипед, бег. Люблю системное мышление и простые решения сложных задач.
        </p>
      </div>
    </div>

    <!-- Contacts -->
    <section class="mt-12 border-t border-gray-100 pt-8">
      <h2 class="text-lg font-semibold text-gray-900">Контакты</h2>
      <ul class="mt-4 space-y-3">
        <li>
          <a
            href="https://t.me/itrokit"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-gray-700 hover:text-gray-900 transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
              ></path>
            </svg>
            @itrokit в Telegram
          </a>
        </li>
      </ul>
    </section>

    <TelegramCTA />
  </main>

  <Footer />
</Base>
