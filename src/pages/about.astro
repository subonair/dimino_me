---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TelegramCTA from '../components/TelegramCTA.astro';

const person = {
  name: 'Дмитрий Иноземцев',
  jobTitle: 'CEO компании «Флексайтс», триатлет',
  url: 'https://dimino.me',
  sameAs: ['https://t.me/itrokit'],
  image: 'https://dimino.me/images/about-photo.webp',
  description:
    'CEO компании «Флексайтс» — с нуля выстроил веб-студию, которая сделала 200+ сайтов. По образованию психолог. Триатлет — плавание, велосипед, бег на длинные дистанции. Пишу о том, что сам проверяю.',
};
---

<Base
  title="Обо мне — блог и контакты"
  description="Дмитрий Иноземцев — CEO компании «Флексайтс», по образованию психолог, триатлет. С нуля выстроил веб-студию, которая сделала 200+ сайтов. Пишу о том, что сам проверяю."
  ogImage="/images/about-photo.webp"
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: person.name,
      jobTitle: person.jobTitle,
      url: person.url,
      sameAs: person.sameAs,
      image: person.image,
      description: person.description,
    })}
  />

  <Header />

  <main class="max-w-3xl mx-auto px-4 py-10">
    <div class="flex flex-col sm:flex-row gap-8 items-start">
      <!-- Avatar -->
      <img
        src="/images/about-photo.webp"
        alt="Дмитрий Иноземцев"
        width="128"
        height="128"
        class="shrink-0 w-24 h-24 sm:w-32 sm:h-32 rounded-2xl object-cover"
        loading="lazy"
        decoding="async"
      />

      <div class="flex-1">
        <h1 class="text-3xl font-bold text-gray-900">{person.name}</h1>
        <p class="mt-1 text-gray-500 text-sm">{person.jobTitle}</p>

        <p class="mt-5 text-gray-700 leading-relaxed">
          {person.description}
        </p>

        <p class="mt-4 text-gray-700 leading-relaxed">
          По образованию психолог — понимаю, как люди принимают решения и почему ломаются процессы.
          В триатлоне проверяю на себе: всё, чем делюсь в блоге, сначала прохожу лично.
        </p>
      </div>
    </div>

    <!-- Services -->
    <section class="mt-12 border-t border-gray-100 pt-8">
      <h2 class="text-lg font-semibold text-gray-900">Чем могу быть полезен</h2>
      <div class="mt-5 grid gap-4 sm:grid-cols-3">
        <div class="p-5 border border-gray-100 rounded-xl">
          <h3 class="font-semibold text-gray-900">Консультация по ИИ</h3>
          <p class="mt-2 text-sm text-gray-500 leading-relaxed">
            Разберём, где ИИ реально помогает в вашем бизнесе, а где — только шум.
          </p>
        </div>
        <div class="p-5 border border-gray-100 rounded-xl">
          <h3 class="font-semibold text-gray-900">Аудит процессов</h3>
          <p class="mt-2 text-sm text-gray-500 leading-relaxed">
            Посмотрю на ваши рабочие процессы и скажу, что автоматизировать, а что оставить.
          </p>
        </div>
        <div class="p-5 border border-gray-100 rounded-xl">
          <h3 class="font-semibold text-gray-900">Менторинг</h3>
          <p class="mt-2 text-sm text-gray-500 leading-relaxed">
            Помогу разобраться в продуктовой разработке и управлении командой.
          </p>
        </div>
      </div>
    </section>

    <!-- Contacts -->
    <section class="mt-12 border-t border-gray-100 pt-8">
      <h2 class="text-lg font-semibold text-gray-900">Контакты</h2>
      <ul class="mt-4 space-y-3">
        <li>
          <a
            href="https://t.me/itrokit"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-gray-700 hover:text-gray-900 transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
              ></path>
            </svg>
            @itrokit в Telegram
          </a>
        </li>
      </ul>
    </section>

    <TelegramCTA />
  </main>

  <Footer />
</Base>
