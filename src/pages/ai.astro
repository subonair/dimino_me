---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import TelegramCTA from '../components/TelegramCTA.astro';

const posts = (await getCollection('blog', ({ data }) => data.category === 'ai')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const pageUrl = 'https://dimino.me/ai/';
const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'ИИ — эксперименты и инструменты',
  description:
    'Искусственный интеллект: практические эксперименты с нейросетями, обзоры ИИ-инструментов и честные выводы без хайпа.',
  url: pageUrl,
  isPartOf: {
    '@type': 'WebSite',
    name: 'Дмитрий Иноземцев',
    url: 'https://dimino.me',
  },
  author: {
    '@type': 'Person',
    name: 'Дмитрий Иноземцев',
    url: 'https://dimino.me/about/',
  },
};
---

<Base
  title="ИИ — эксперименты и инструменты"
  description="Искусственный интеллект: практические эксперименты с нейросетями, обзоры ИИ-инструментов и честные выводы без хайпа. Проверяю на себе и делюсь результатами."
>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  <Header />

  <main class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900">ИИ</h1>
    <p class="mt-3 text-gray-500">
      Эксперименты, инструменты и честные выводы про искусственный интеллект.
    </p>

    <div class="mt-10">
      {
        posts.length > 0 ? (
          <div class="grid gap-4 sm:grid-cols-2">
            {posts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date.toISOString().split('T')[0]}
                slug={`${post.data.category}/${post.id.split('/').pop()?.replace(/\.md$/, '')}`}
                image={post.data.image}
                href={`/${post.id.replace(/\.md$/, '')}/`}
              />
            ))}
          </div>
        ) : (
          <div class="py-16 text-center border border-dashed border-gray-200 rounded-2xl">
            <p class="text-gray-400 text-sm">Посты скоро появятся</p>
          </div>
        )
      }
    </div>

    <TelegramCTA message="Слежу за ИИ каждый день — подписывайся, чтобы не пропустить." />
  </main>

  <Footer />
</Base>
