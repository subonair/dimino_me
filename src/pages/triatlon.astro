---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import TelegramCTA from '../components/TelegramCTA.astro';

const posts = (await getCollection('blog', ({ data }) => data.category === 'triatlon')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Триатлон — тренировки и гонки',
  description:
    'Раздел о триатлоне: тренировки, гонки, снаряжение и всё, что помогает финишировать. Плавание, велосипед, бег — личный опыт и практические советы триатлета.',
  url: 'https://dimino.me/triatlon/',
  isPartOf: {
    '@type': 'WebSite',
    name: 'Дмитрий Иноземцев',
    url: 'https://dimino.me',
  },
  author: {
    '@type': 'Person',
    name: 'Дмитрий Иноземцев',
    url: 'https://dimino.me/about/',
  },
};
---

<Base
  title="Триатлон — тренировки и гонки"
  description="Раздел о триатлоне: тренировки, гонки, снаряжение и всё, что помогает финишировать. Плавание, велосипед, бег — личный опыт и практические советы триатлета."
>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  <Header />

  <main class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900">Триатлон</h1>
    <p class="mt-3 text-gray-500">
      Тренировки, гонки, снаряжение и всё, что помогает финишировать.
    </p>

    <!-- Все старты → -->
    <div class="mt-12 flex flex-wrap gap-4">
      <a
        href="/triatlon/events/"
        class="inline-flex items-center gap-1 text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors"
      >
        Все старты →
      </a>
      <a
        href="/triatlon/calc/"
        class="inline-flex items-center gap-1 text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors"
      >
        Калькулятор триатлона
      </a>
    </div>

    <!-- Посты -->
    <section class="mt-12">
      <h2 class="text-xl font-semibold text-gray-800">Заметки о триатлоне</h2>

      <div class="mt-4">
        {
          posts.length > 0 ? (
            <div class="grid gap-4 sm:grid-cols-2">
              {posts.map((post) => (
                <PostCard
                  title={post.data.title}
                  description={post.data.description}
                  date={post.data.date.toISOString().split('T')[0]}
                  slug={`${post.data.category}/${post.id.split('/').pop()?.replace(/\.md$/, '')}`}
                  image={post.data.image}
                  href={`/${post.id.replace(/\.md$/, '')}/`}
                />
              ))}
            </div>
          ) : (
            <div class="py-16 text-center border border-dashed border-gray-200 rounded-2xl">
              <p class="text-gray-400 text-sm">Посты скоро появятся</p>
            </div>
          )
        }
      </div>
    </section>

    <TelegramCTA
      message="Готовлюсь к следующей гонке — подписывайся, пишу о тренировочном процессе."
    />
  </main>

  <Footer />
</Base>
