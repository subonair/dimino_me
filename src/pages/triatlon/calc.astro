---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Base title="Калькулятор триатлона" description="Калькулятор темпа и финишного времени для триатлона. Рассчитайте свой результат на Ironman, Half-Ironman, Olympic, Sprint по темпу на плавании, велосипеде и беге.">
  <Header />
  <main class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900">Калькулятор триатлона</h1>
    <p class="mt-3 text-gray-500">Рассчитайте финишное время и темп для любой дистанции триатлона.</p>

    <div id="tricalc" class="mt-8 bg-white border border-gray-200 rounded-2xl p-6 space-y-6">
      <!-- Distances preset -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Дистанция</label>
        <div class="flex flex-wrap gap-2">
          {['Ironman', 'Half-Ironman', 'Olympic', 'Sprint', 'Super Sprint', 'Custom'].map((d) => (
            <button class="distance-btn px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 bg-white text-gray-600 hover:border-blue-300 hover:text-blue-600 transition-colors" data-distance={d}>{d}</button>
          ))}
        </div>
      </div>

      <!-- Disciplines -->
      <div class="grid gap-4 sm:grid-cols-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">🏊 Плавание</label>
          <div class="flex items-center gap-2">
            <input type="number" id="swim-dist" value="3.86" step="0.1" min="0" class="w-20 px-2 py-1.5 border border-gray-200 rounded-lg text-sm text-center" />
            <span class="text-sm text-gray-400">км</span>
          </div>
          <div class="mt-1 flex items-center gap-2">
            <input type="text" id="swim-pace" value="2:00" placeholder="мм:cc" class="w-20 px-2 py-1.5 border border-gray-200 rounded-lg text-sm text-center" />
            <span class="text-sm text-gray-400">/100м</span>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">🚴 Велосипед</label>
          <div class="flex items-center gap-2">
            <input type="number" id="bike-dist" value="180.25" step="0.1" min="0" class="w-20 px-2 py-1.5 border border-gray-200 rounded-lg text-sm text-center" />
            <span class="text-sm text-gray-400">км</span>
          </div>
          <div class="mt-1 flex items-center gap-2">
            <input type="number" id="bike-speed" value="30" step="0.5" min="0" class="w-20 px-2 py-1.5 border border-gray-200 rounded-lg text-sm text-center" />
            <span class="text-sm text-gray-400">км/ч</span>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">🏃 Бег</label>
          <div class="flex items-center gap-2">
            <input type="number" id="run-dist" value="42.2" step="0.1" min="0" class="w-20 px-2 py-1.5 border border-gray-200 rounded-lg text-sm text-center" />
            <span class="text-sm text-gray-400">км</span>
          </div>
          <div class="mt-1 flex items-center gap-2">
            <input type="text" id="run-pace" value="5:00" placeholder="мм:сс" class="w-20 px-2 py-1.5 border border-gray-200 rounded-lg text-sm text-center" />
            <span class="text-sm text-gray-400">/км</span>
          </div>
        </div>
      </div>

      <!-- Transition times -->
      <div class="flex gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">T1 (S→B)</label>
          <input type="text" id="t1" value="5:00" class="w-20 px-2 py-1.5 border border-gray-200 rounded-lg text-sm text-center" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">T2 (B→R)</label>
          <input type="text" id="t2" value="3:00" class="w-20 px-2 py-1.5 border border-gray-200 rounded-lg text-sm text-center" />
        </div>
      </div>

      <!-- Results -->
      <div class="bg-gray-50 rounded-xl p-5">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Результат</h3>
        <div class="mt-3 grid gap-3 sm:grid-cols-4">
          <div>
            <div class="text-xs text-gray-400">🏊 Плавание</div>
            <div id="res-swim" class="text-lg font-bold text-gray-900">--</div>
          </div>
          <div>
            <div class="text-xs text-gray-400">🚴 Вело + T1</div>
            <div id="res-bike" class="text-lg font-bold text-gray-900">--</div>
          </div>
          <div>
            <div class="text-xs text-gray-400">🏃 Бег + T2</div>
            <div id="res-run" class="text-lg font-bold text-gray-900">--</div>
          </div>
          <div>
            <div class="text-xs text-gray-400">🏁 Финиш</div>
            <div id="res-total" class="text-2xl font-bold text-blue-600">--</div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    const presets = {
      'Ironman': { swim: 3.86, bike: 180.25, run: 42.2 },
      'Half-Ironman': { swim: 1.9, bike: 90, run: 21.1 },
      'Olympic': { swim: 1.5, bike: 40, run: 10 },
      'Sprint': { swim: 0.75, bike: 20, run: 5 },
      'Super Sprint': { swim: 0.4, bike: 10, run: 2.5 },
    };

    function parseTime(str) {
      const parts = str.split(':').map(Number);
      if (parts.length === 2) return parts[0] * 60 + parts[1];
      if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
      return 0;
    }

    function formatTime(sec) {
      const h = Math.floor(sec / 3600);
      const m = Math.floor((sec % 3600) / 60);
      const s = Math.floor(sec % 60);
      if (h > 0) return `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
      return `${m}:${String(s).padStart(2, '0')}`;
    }

    function calc() {
      const swimDist = parseFloat(document.getElementById('swim-dist').value) || 0;
      const swimPace = parseTime(document.getElementById('swim-pace').value);
      const bikeDist = parseFloat(document.getElementById('bike-dist').value) || 0;
      const bikeSpeed = parseFloat(document.getElementById('bike-speed').value) || 0;
      const runDist = parseFloat(document.getElementById('run-dist').value) || 0;
      const runPace = parseTime(document.getElementById('run-pace').value);
      const t1 = parseTime(document.getElementById('t1').value);
      const t2 = parseTime(document.getElementById('t2').value);

      const swimTime = swimDist > 0 ? (swimDist * 1000 / 100) * swimPace : 0;
      const bikeTime = bikeSpeed > 0 ? (bikeDist / bikeSpeed) * 3600 : 0;
      const runTime = runDist > 0 ? runDist * runPace : 0;

      document.getElementById('res-swim').textContent = formatTime(swimTime);
      document.getElementById('res-bike').textContent = formatTime(bikeTime + t1);
      document.getElementById('res-run').textContent = formatTime(runTime + t2);
      document.getElementById('res-total').textContent = formatTime(swimTime + bikeTime + runTime + t1 + t2);
    }

    document.querySelectorAll('.distance-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.distance-btn').forEach(b => b.classList.remove('bg-blue-50', 'border-blue-300', 'text-blue-600'));
        btn.classList.add('bg-blue-50', 'border-blue-300', 'text-blue-600');
        const preset = presets[btn.dataset.distance];
        if (preset) {
          document.getElementById('swim-dist').value = preset.swim;
          document.getElementById('bike-dist').value = preset.bike;
          document.getElementById('run-dist').value = preset.run;
        }
        calc();
      });
    });

    document.querySelectorAll('#tricalc input').forEach(input => {
      input.addEventListener('input', calc);
    });

    calc();
  </script>

  <Footer />
</Base>
