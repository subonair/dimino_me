---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import EventCard from '../../components/EventCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const events = (await getCollection('events')).sort(
  (a, b) => a.data.date.valueOf() - b.data.date.valueOf(),
);

const now = new Date();
const upcoming = events.filter((e) => e.data.date >= now);
const past = events.filter((e) => e.data.date < now);

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Календарь стартов IronStar',
  description:
    'Календарь триатлонных стартов IronStar: даты соревнований, дистанции, стоимость участия и регистрация. Ближайшие и прошедшие события — всё в одном месте.',
  url: 'https://dimino.me/triatlon/events/',
  isPartOf: {
    '@type': 'WebSite',
    name: 'Дмитрий Иноземцев',
    url: 'https://dimino.me',
  },
};
---

<Base
  title="Календарь стартов IronStar"
  description="Календарь триатлонных стартов IronStar: даты соревнований, дистанции, стоимость участия и регистрация. Ближайшие и прошедшие события — всё в одном месте."
>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  <Header />
  <Breadcrumbs
    items={[
      { label: 'Главная', href: '/' },
      { label: 'Триатлон', href: '/triatlon/' },
      { label: 'Календарь стартов' },
    ]}
  />

  <main class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900">Календарь стартов</h1>
    <p class="mt-3 text-gray-500">
      События по триатлону, бегу и плаванию в России и за её пределами.
    </p>

    <div
      class="mt-6 bg-blue-50 border border-blue-100 rounded-2xl p-5 text-sm text-gray-700 space-y-3"
    >
      <p>
        В поиске стартов я столкнулся с проблемой - сложно в одном месте найти всю информацию по
        всем стартам. Для моего удобства, с помощью ИИ-агентов, я собрал информацию из открытых
        источников. Сейчас в базе <strong>3 источника</strong> и она постоянно пополняется.
      </p>
      <p>
        Не нашли свой старт?
        <a
          href="https://t.me/subonair"
          class="font-medium text-blue-600 hover:underline"
          target="_blank">Напишите мне в Telegram</a
        > — я добавлю его в Календарь стартов.
      </p>
    </div>

    <!-- Upcoming events -->
    {
      upcoming.length > 0 && (
        <section class="mt-10">
          <h2 class="text-xl font-semibold text-gray-800">Ближайшие старты ({upcoming.length})</h2>

          <div class="mt-4 space-y-2">
            {upcoming.map((event) => (
              <EventCard
                title={event.data.title}
                date={event.data.date}
                city={event.data.city}
                sportType={event.data.sportType}
                status={event.data.status}
                audience={event.data.audience}
                distances={event.data.distances}
                distanceLabel={event.data.distanceLabel}
                sourceUrl={event.data.sourceUrl}
                prices={event.data.prices}
              />
            ))}
          </div>
        </section>
      )
    }

    <!-- Past events (collapsed) -->
    {
      past.length > 0 && (
        <section class="mt-10">
          <details>
            <summary class="text-xl font-semibold text-gray-800 cursor-pointer">
              Прошедшие старты ({past.length})
            </summary>

            <div class="mt-4 space-y-2">
              {past.map((event) => (
                <EventCard
                  title={event.data.title}
                  date={event.data.date}
                  city={event.data.city}
                  sportType={event.data.sportType}
                  status={event.data.status}
                  audience={event.data.audience}
                  distances={event.data.distances}
                  distanceLabel={event.data.distanceLabel}
                  sourceUrl={event.data.sourceUrl}
                  prices={event.data.prices}
                />
              ))}
            </div>
          </details>
        </section>
      )
    }

    <div class="mt-8">
      <a href="/triatlon/" class="text-sm text-blue-600 hover:text-blue-800 transition-colors">
        ← Назад к триатлону
      </a>
    </div>
  </main>

  <Footer />
</Base>
