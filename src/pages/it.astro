---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import TelegramCTA from '../components/TelegramCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const posts = (await getCollection('blog', ({ data }) => data.category === 'it')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'IT — технологии и разработка',
  description:
    'IT-раздел: технологии, разработка продуктов, управление командой и карьера. Пишу о том, что реально работает.',
  url: 'https://dimino.me/it/',
  isPartOf: {
    '@type': 'WebSite',
    name: 'Дмитрий Иноземцев',
    url: 'https://dimino.me',
  },
  author: {
    '@type': 'Person',
    name: 'Дмитрий Иноземцев',
    url: 'https://dimino.me/about/',
  },
};
---

<Base
  title="IT — технологии и разработка"
  description="IT-раздел: технологии, разработка продуктов, управление командой и карьера. Пишу о том, что реально работает — из опыта в продуктовой разработке."
>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  <Header />
  <Breadcrumbs items={[{ label: 'Главная', href: '/' }, { label: 'IT' }]} />

  <main class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900">IT</h1>
    <p class="mt-3 text-gray-500">Технологии, разработка, продукт и карьера в IT.</p>

    <div class="mt-10">
      {
        posts.length > 0 ? (
          <div class="grid gap-4">
            {posts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date.toISOString().split('T')[0]}
                slug={`${post.data.category}/${post.id.split('/').pop()?.replace(/\.md$/, '')}`}
                image={post.data.image}
                href={`/${post.id.replace(/\.md$/, '')}/`}
              />
            ))}
          </div>
        ) : (
          <div class="py-16 text-center border border-dashed border-gray-200 rounded-2xl">
            <p class="text-gray-400 text-sm">Посты скоро появятся</p>
          </div>
        )
      }
    </div>

    <TelegramCTA message="Пишу об IT честно — что работает, что нет." />
  </main>

  <Footer />
</Base>
