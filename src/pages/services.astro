---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import TelegramCTA from '../components/TelegramCTA.astro';

const servicesList = [
  {
    title: 'Консультация по ИИ',
    description: 'Разберём, где ИИ реально помогает в вашем бизнесе, а где — только шум.',
  },
  {
    title: 'Аудит процессов',
    description: 'Посмотрю на ваши рабочие процессы и скажу, что автоматизировать, а что оставить.',
  },
  {
    title: 'Менторинг',
    description: 'Помогу разобраться в продуктовой разработке и управлении командой.',
  },
];

const posts = (await getCollection('blog', ({ data }) => data.category === 'services')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Base title="Услуги" description="Чем могу быть полезен — консультации по ИИ и процессам">
  <Header />

  <main class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-gray-900">Услуги</h1>
    <p class="mt-3 text-gray-500">
      Работаю с командами и основателями — помогаю внедрять ИИ и строить процессы.
    </p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        servicesList.map(({ title, description }) => (
          <div class="p-5 border border-gray-100 rounded-xl">
            <h2 class="font-semibold text-gray-900">{title}</h2>
            <p class="mt-2 text-sm text-gray-500 leading-relaxed">{description}</p>
          </div>
        ))
      }
    </div>

    {
      posts.length > 0 && (
        <div class="mt-12">
          <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-5">Статьи</h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {posts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date.toISOString().split('T')[0]}
                image={post.data.image}
                href={`/${post.id.replace(/\.md$/, '')}/`}
              />
            ))}
          </div>
        </div>
      )
    }

    <TelegramCTA message="Обсудим задачу? Пишите напрямую." />
  </main>

  <Footer />
</Base>
